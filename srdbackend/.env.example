PORT=3000

# String de conexão do MongoDB (local ou Atlas)
MONGODB_URI=mongodb://localhost:27017

# Nome do banco de dados utilizado pela aplicação
MONGODB_DB_NAME=sdr_crm

# Chave da API da OpenAI usada pelo SDR Virtual (POST /api/v1/sdr/message)
OPENAI_API_KEY=

# Modelo usado pelo SDR Virtual (opcional, padrão: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Modelo de embeddings
VOYAGE_API_KEY=